# SkillHub server environment variables.
# Copy to .env and adjust for your environment.

# API listen address (default: ":8080")
SKILLHUB_API_ADDR=:8080

# Comma-separated browser origins allowed to call the API.
# Leave empty for same-origin only. Use explicit origins for credentialed requests.
SKILLHUB_CORS_ALLOWED_ORIGINS=http://localhost:5173

# PostgreSQL connection URL
SKILLHUB_DATABASE_URL=postgres://skillhub:skillhub@localhost:5432/skillhub?sslmode=disable

# Redis connection URL
SKILLHUB_REDIS_URL=redis://localhost:6379/0

# S3-compatible object storage endpoint (e.g. MinIO)
SKILLHUB_STORAGE_ENDPOINT=localhost:9000

# Object storage bucket
SKILLHUB_STORAGE_BUCKET=skillhub

# Object storage credentials
SKILLHUB_STORAGE_ACCESS_KEY=minioadmin
SKILLHUB_STORAGE_SECRET_KEY=minioadmin

# Set to "true" to skip external dependency checks (local development).
# Local development defaults are intentionally weak.
# Production must set SKILLHUB_LOCAL_MODE=false and replace all credentials.
SKILLHUB_LOCAL_MODE=true

# Comma-separated CIDR blocks for trusted reverse proxies.
# X-Forwarded-For is only trusted from these IP ranges.
# Leave empty to ignore X-Forwarded-For entirely (safe default).
SKILLHUB_TRUSTED_PROXY_CIDRS=
