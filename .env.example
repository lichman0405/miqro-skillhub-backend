# SkillHub server environment variables.
# Copy to .env and adjust for your environment.

# API listen address (default: ":8080")
SKILLHUB_API_ADDR=:8080

# Comma-separated browser origins allowed to call the API.
# Leave empty for same-origin only. Use explicit origins for credentialed requests.
SKILLHUB_CORS_ALLOWED_ORIGINS=http://localhost:5173

# PostgreSQL connection URL
SKILLHUB_DATABASE_URL=postgres://skillhub:skillhub@localhost:5432/skillhub?sslmode=disable

# Redis connection URL. Required when SKILLHUB_SESSION_BACKEND=redis or
# SKILLHUB_RATE_LIMIT_BACKEND=redis.
SKILLHUB_REDIS_URL=redis://localhost:6379/0

# Session storage backend: "none" (default) or "redis".
# When "redis", login creates a HttpOnly skillhub_session cookie.
SKILLHUB_SESSION_BACKEND=none

# Server-side session TTL (default: 24h).
SKILLHUB_SESSION_TTL=24h

# Set the Secure flag on the skillhub_session cookie.
# Must be true when using Redis-backed sessions in production.
SKILLHUB_SESSION_COOKIE_SECURE=false

# Rate-limit backend: "memory" (default, in-process) or "redis" (distributed).
SKILLHUB_RATE_LIMIT_BACKEND=memory

# ---------------------------------------------------------------------------
# Object storage configuration
# ---------------------------------------------------------------------------

# Storage provider: "local" (filesystem) or "s3" (S3-compatible / MinIO).
SKILLHUB_STORAGE_PROVIDER=local

# Local filesystem storage root (used when SKILLHUB_STORAGE_PROVIDER=local).
SKILLHUB_STORAGE_ROOT=./data/storage

# S3-compatible object storage endpoint (used when SKILLHUB_STORAGE_PROVIDER=s3).
SKILLHUB_STORAGE_ENDPOINT=localhost:9000

# Object storage bucket (used when SKILLHUB_STORAGE_PROVIDER=s3).
SKILLHUB_STORAGE_BUCKET=skillhub

# Object storage credentials (used when SKILLHUB_STORAGE_PROVIDER=s3).
SKILLHUB_STORAGE_ACCESS_KEY=minioadmin
SKILLHUB_STORAGE_SECRET_KEY=minioadmin

# Enable TLS for the S3 endpoint (used when SKILLHUB_STORAGE_PROVIDER=s3).
SKILLHUB_STORAGE_USE_SSL=false

# S3 region (used when SKILLHUB_STORAGE_PROVIDER=s3).
SKILLHUB_STORAGE_REGION=us-east-1

# Allow local filesystem storage in production mode.
# Only enable this as an emergency override; prefer S3 for production.
SKILLHUB_ALLOW_LOCAL_STORAGE_IN_PRODUCTION=false

# ---------------------------------------------------------------------------

# Set to "true" to skip external dependency checks (local development).
# Local development defaults are intentionally weak.
# Production must set SKILLHUB_LOCAL_MODE=false and replace all credentials.
SKILLHUB_LOCAL_MODE=true

# Comma-separated CIDR blocks for trusted reverse proxies.
# X-Forwarded-For is only trusted from these IP ranges.
# Leave empty to ignore X-Forwarded-For entirely (safe default).
SKILLHUB_TRUSTED_PROXY_CIDRS=
